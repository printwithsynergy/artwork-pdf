{
  "name": "@printwithsynergy/artwork-pdf-editor",
  "version": "0.5.4",
  "description": "artworkPDF WYSIWYG editor as a host-customizable React component. Drop-in mountable in Next.js, Astro, Remix, etc.",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./lens": {
      "types": "./dist/lens/index.d.ts",
      "import": "./dist/lens/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@printwithsynergy/dieline-parser": "workspace:*",
    "pdf-lib": "^1.17.1",
    "three": "^0.170.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-konva": "^19.0.0",
    "konva": "^10.3.0",
    "@printwithsynergy/lens-pdf": "^0.4.0-beta.17"
  },
  "peerDependenciesMeta": {
    "@printwithsynergy/lens-pdf": { "optional": true }
  },
  "devDependencies": {
    "@printwithsynergy/lens-pdf": "^0.4.0-beta.17",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.170.0",
    "konva": "^10.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-konva": "^19.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
