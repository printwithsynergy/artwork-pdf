{
  "name": "@artworkpdf/document-model",
  "version": "0.3.0",
  "description": "artworkPDF document schema and types — JSON Schema emitted for cross-language consumers (compile-pdf)",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./schema": "./dist/schema/document-model.schema.json",
    "./schema/v2": "./dist/schema/document-model.v2.schema.json",
    "./schema/v3": "./dist/schema/document-model.v3.schema.json"
  },
  "files": [
    "dist",
    "scripts"
  ],
  "scripts": {
    "build": "tsc && pnpm run schema:emit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "schema:emit": "tsx scripts/emit-schema.ts"
  },
  "devDependencies": {
    "ts-json-schema-generator": "^2.9.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
