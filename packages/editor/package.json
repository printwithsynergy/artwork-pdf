{
  "name": "@artworkpdf/editor",
  "version": "1.0.0",
  "description": "ArtworkPDF full Illustrator-grade editor components",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./styles.css": "./dist/styles.css"
  },
  "scripts": {
    "build": "tsc --noEmitOnError false; tailwindcss -i ./src/styles.css -o ./dist/styles.css",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@artworkpdf/document-model": "workspace:*",
    "konva": "^10.3.0",
    "react-konva": "^19.0.0",
    "use-image": "^1.1.0",
    "typo-js": "^1.2.1"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/typo-js": "^1.2.2",
    "react": "^19.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7",
    "tailwindcss": "^4.3.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
