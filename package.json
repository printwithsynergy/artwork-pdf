{
  "name": "artwork-pdf",
  "private": true,
  "description": "WYSIWYG label & packaging artwork editor — synergy node, AGPL-3.0-or-later",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "engines": { "node": ">=22", "pnpm": ">=10" },
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "test": "turbo test",
    "lint": "biome check --write .",
    "lint:check": "biome lint .",
    "format:check": "biome format .",
    "typecheck": "turbo typecheck",
    "check-licenses": "node scripts/check-license-boundary.mjs",
    "symbols": "node scripts/gen-symbols.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/node": "^25.9.1",
    "turbo": "^2.3.0",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": ["@biomejs/biome", "esbuild", "sharp"]
  }
}
