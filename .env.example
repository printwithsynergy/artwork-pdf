# artworkPDF — environment variables
# Copy to .env and fill in values

DATABASE_URL=postgresql://artworkpdf:artworkpdf@localhost:5432/artworkpdf
NODE_ENV=development
PORT=3001

# AGPL §13 source route
GIT_SHA=dev
SOURCE_URL=https://github.com/printwithsynergy/artwork-pdf

# Ghostscript for PDF/X-4 conformance
GHOSTSCRIPT_BIN=/usr/bin/gs

# pg-boss job queue
PG_BOSS_SCHEMA=pgboss
SSE_HEARTBEAT_MS=15000

# Editor
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SERVICE_URL=http://localhost:3001
